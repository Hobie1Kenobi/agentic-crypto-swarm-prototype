# Unified host → Base x402 (8043), T54 XRPL (8765), Marketplace (8055)
# Docs: scripts/reverse-proxy/README.md
# Run: npm run proxy:unified   OR   caddy run --config scripts/reverse-proxy/Caddyfile
# Listen: 127.0.0.1:9080 — point ngrok at 9080 (scripts/ngrok-unified-stack.yml)

:9080 {
	encode zstd gzip

	# Marketplace (Stripe webhooks, buyer API, portal)
	handle /webhooks/* {
		reverse_proxy 127.0.0.1:8055
	}
	handle /v1/* {
		reverse_proxy 127.0.0.1:8055
	}
	handle /marketplace/* {
		reverse_proxy 127.0.0.1:8055
	}
	handle /openapi.json {
		reverse_proxy 127.0.0.1:8055
	}
	handle /docs* {
		reverse_proxy 127.0.0.1:8055
	}
	handle /redoc* {
		reverse_proxy 127.0.0.1:8055
	}

	# Celo-native api_402 (/query + POST) — must be before default catch-all
	handle /query {
		reverse_proxy 127.0.0.1:8042
	}

	# Base x402 Bazaar (same paths as direct :8043). /.well-known/* (x402.json, agent-card.json, mcp.json)
	# is served by the same FastAPI app on 8043 — no separate static root required.
	handle /x402/* {
		reverse_proxy 127.0.0.1:8043 {
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
	}
	handle /.well-known/* {
		reverse_proxy 127.0.0.1:8043 {
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
	}

	# T54 XRPL seller — full /t54/* path forwarded (x402 resource URLs must include prefix)
	handle /t54/* {
		reverse_proxy 127.0.0.1:8765 {
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
	}

	# MCP Streamable HTTP (Smithery, Glama URL) — full path /mcp on backend (no strip)
	# Start: python scripts/mcp_server.py --transport streamable-http --host 127.0.0.1 --port 9052
	@mcpstream {
		path /mcp /mcp/
	}
	handle @mcpstream {
		reverse_proxy 127.0.0.1:9052
	}
	# MCP SSE — strip /mcp prefix → backend /sse and /messages/
	# Start: python scripts/mcp_server.py --transport sse --host 127.0.0.1 --port 9051
	handle /mcp/* {
		uri strip_prefix /mcp
		reverse_proxy 127.0.0.1:9051
	}

	# Daydreams bounty agents (agent-kit + x402)
	handle /agents/fresh-markets-watch/* {
		uri strip_prefix /agents/fresh-markets-watch
		reverse_proxy 127.0.0.1:8091
	}
	handle /agents/slippage-sentinel/* {
		uri strip_prefix /agents/slippage-sentinel
		reverse_proxy 127.0.0.1:8092
	}
	handle /agents/gas-route-oracle/* {
		uri strip_prefix /agents/gas-route-oracle
		reverse_proxy 127.0.0.1:8093
	}
	handle /agents/approval-risk-auditor/* {
		uri strip_prefix /agents/approval-risk-auditor
		reverse_proxy 127.0.0.1:8095
	}
	handle /agents/yield-pool-watcher/* {
		uri strip_prefix /agents/yield-pool-watcher
		reverse_proxy 127.0.0.1:8096
	}
	handle /agents/bridge-route-pinger/* {
		uri strip_prefix /agents/bridge-route-pinger
		reverse_proxy 127.0.0.1:8100
	}
	handle /agents/perps-funding-pulse/* {
		uri strip_prefix /agents/perps-funding-pulse
		reverse_proxy 127.0.0.1:8101
	}
	handle /agents/lending-liquidation-sentinel/* {
		uri strip_prefix /agents/lending-liquidation-sentinel
		reverse_proxy 127.0.0.1:8102
	}
	handle /agents/lp-il-estimator/* {
		uri strip_prefix /agents/lp-il-estimator
		reverse_proxy 127.0.0.1:8103
	}
	handle /agents/cross-dex-arbitrage-alert/* {
		uri strip_prefix /agents/cross-dex-arbitrage-alert
		reverse_proxy 127.0.0.1:8104
	}

	# Default: Base seller (e.g. /health on x402 app)
	handle {
		reverse_proxy 127.0.0.1:8043 {
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
	}
}
