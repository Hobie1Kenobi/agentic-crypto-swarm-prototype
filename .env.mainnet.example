# Celo mainnet production profile (chain ID 42220)
# Copy to .env.mainnet (gitignored). Put ONLY mainnet-specific overrides here (CHAIN_ID, RPC, mainnet contract addresses).
# Leave secrets blank (PRIVATE_KEY=, XRPL_WALLET_SEED=, etc.) to reuse values from your existing .env when you run: npm run env:mainnet
# That command merges: non-empty lines here override .env; empty lines keep whatever is already in .env.
# Full replace: .\scripts\activate-mainnet-env.ps1 -Replace
# Triple rail: docs/MAINNET_CELO_XRPL_T54.md | pip install xrpl-py for live XRPL

CHAIN_NAME=celo-mainnet
CHAIN_ID=42220
# Prefer a dedicated provider URL for production; public default below is a fallback only
RPC_URL=
CELO_MAINNET_RPC_URL=https://rpc.ankr.com/celo
CELO_SEPOLIA_RPC_URL=
CELO_RPC_URL=
EXPLORER_URL=https://explorer.celo.org

PRIVATE_CHAIN_NAME=celo-mainnet
PRIVATE_CHAIN_ID=42220
# Set to same HTTPS URL as CELO_MAINNET_RPC_URL or RPC_URL when using this profile
PRIVATE_RPC_URL=
PRIVATE_EXPLORER_URL=https://explorer.celo.org
PRIVATE_MARKETPLACE_ADDRESS=
PRIVATE_REVENUE_SERVICE_ADDRESS=

PUBLIC_OLAS_CHAIN_NAME=gnosis
PUBLIC_OLAS_CHAIN_ID=100
PUBLIC_OLAS_RPC_URL=
PUBLIC_OLAS_EXPLORER_URL=

# hybrid + XRPL payment + Celo private settlement (multi_rail_hybrid). Use private_celo + direct_onchain_celo_payment for Celo-only.
MARKET_MODE=hybrid
REPORT_OUTPUT_DIR=
PAYMENT_RAIL_MODE=hybrid_public_request_xrpl_payment_private_celo_settlement

# XRPL rail (machine payments; multi_rail uses direct Payment via xrpl-py — not the T54 facilitator). See docs/XRPL_PAYMENTS.md
XRPL_ENABLED=1
XRPL_NETWORK=mainnet
XRPL_RPC_URL=https://xrplcluster.com
XRPL_WALLET_SEED=
XRPL_RECEIVER_ADDRESS=
XRPL_SETTLEMENT_ASSET=XRP
XRPL_ALLOW_MOCK_FALLBACK=0
XRPL_X402_ENABLED=0
XRPL_X402_FACILITATOR_URL=
XRPL_PAYMENT_MODE=live

# T54 x402 (HTTP 402 + facilitator; external commerce / x402 sellers). Same seed as XRPL if unset — see docs/MAINNET_CELO_XRPL_T54.md
T54_XRPL_ENABLED=1
T54_XRPL_MODE=mainnet
T54_XRPL_FACILITATOR_URL=https://xrpl-facilitator-mainnet.t54.ai
T54_XRPL_NETWORK=mainnet
T54_XRPL_NETWORK_PASSPHRASE=
T54_XRPL_REQUIRE_VALIDATED=0
T54_XRPL_WALLET_SEED=
T54_XRPL_WALLET_ADDRESS=
T54_XRPL_RECEIVER_ADDRESS=
T54_XRPL_ALLOW_SIMULATED_TESTNET=0
T54_XRPL_DEFAULT_CURRENCY=XRP
T54_XRPL_TIMEOUT_MS=30000
T54_XRPL_DRY_RUN=0
# HTTPS (or http://127.0.0.1:8765/hello) URL of an x402 merchant that returns 402 + XRPL terms; see npm run t54:cycle
T54_X402_RESOURCE_URL=
# T54 seller-only server (npm run t54:seller) — no private keys; pay_to = XRPL_RECEIVER_ADDRESS
T54_SELLER_HOST=127.0.0.1
T54_SELLER_PORT=8765
# Per-SKU prices are in packages/agents/config/t54_seller_skus.json (override path with T54_SELLER_SKUS_JSON)
T54_SELLER_SKUS_JSON=
T54_SELLER_NETWORK=xrpl:0
T54_SELLER_DESCRIPTION=Swarm T54 XRPL x402 seller
T54_LOCAL_MERCHANT_PAY_TO=
# Public origin for discovery (no path): sets resource_url for all T54 SKU rows in x402_providers.json
# With both sellers up (8765 + 8043): npm run stack:dual-ngrok — merges authtoken config + dual tunnels, syncs T54 + Base x402 URLs into .env / .env.mainnet
T54_SELLER_PUBLIC_BASE_URL=
T54_SELLER_PUBLIC_URL=
T54_SELLER_PROBE_URL=

OLAS_ENABLED=0
OLAS_CHAIN_CONFIG=gnosis
OLAS_PRIORITY_MECH_ADDRESS=
OLAS_TOOL=openai-gpt-4o-2024-05-13
OLAS_EOA_PRIVATE_KEY=
OLAS_DELIVERY_TIMEOUT_SEC=180
OLAS_MECHX_PATH=

ALCHEMY_API_KEY=

OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434

BENEFICIARY_ADDRESS=0x0000000000000000000000000000000000000000

PIMLICO_API_KEY=
BUNDLER_RPC_URL=
PAYMASTER_RPC_URL=

ROOT_STRATEGIST_PRIVATE_KEY=
IP_GENERATOR_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=
FINANCE_DISTRIBUTOR_PRIVATE_KEY=

WORKER_PRIVATE_KEY=
VALIDATOR_PRIVATE_KEY=
TREASURY_PRIVATE_KEY=

ROOT_STRATEGIST_ADDRESS=
IP_GENERATOR_ADDRESS=
DEPLOYER_ADDRESS=
FINANCE_DISTRIBUTOR_ADDRESS=

PRIVATE_KEY=

TREASURY_ADDRESS=
REVENUE_SERVICE_ADDRESS=
CONSTITUTION_ADDRESS=
COMPUTE_MARKETPLACE_ADDRESS=

COMPUTE_MINER_METADATA=swarm-agent-1
COMPUTE_MINER_URLS=http://127.0.0.1:8043
COMPUTE_TASK_QUERY=What is one ethical use of AI?

PAYMENT_TOKEN_ADDRESS=

OPENAI_API_KEY=
GROQ_API_KEY=

# Base USDC — facilitator x402 seller (Coinbase Bazaar; api_seller_x402.py, default port 8043). Not XRPL — 0x receive only.
# X402_SELLER_PAY_TO=0xYourBaseMainnetAddress
# X402_SELLER_NETWORK=eip155:8453
# X402_TEST_FACILITATOR_URL=https://x402.org/facilitator
# X402_SELLER_PRICE=$0.01
# X402_SELLER_HOST=127.0.0.1
# X402_SELLER_PORT=8043
# Required for Bazaar / discovery: HTTPS URL to this exact route (after ngrok or VPS)
# X402_SELLER_PUBLIC_URL=https://your-host/x402/v1/query
# SELLER_ACCESS_LOG=../logs/x402-base-seller-access.jsonl
# Buyer + discovery (when invoking other x402 resources or refreshing catalog)
# X402_ENABLED=1
# X402_DISCOVERY_ENABLED=1
# X402_ALLOWED_NETWORKS=eip155:8453,eip155:84532

# Merge additional keys from .env.example as needed (x402, customer balance, soak flags, etc.)
# Optional: USE_LEGACY_TXS=1 if your RPC requires legacy txs for deploy (see scripts/deploy.ps1)
# Optional: ETH_GAS_PRICE / ETH_PRIORITY_GAS_PRICE for forge broadcast caps
