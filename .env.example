# Chain (Celo-first: celo-sepolia testnet, celo-mainnet production; local: anvil)
# Celo Sepolia public test: CHAIN_NAME=celo-sepolia, CHAIN_ID=11142220, set RPC and fund deployer + ROOT_STRATEGIST
CHAIN_NAME=celo-sepolia
CHAIN_ID=11142220
RPC_URL=
CELO_SEPOLIA_RPC_URL=
CELO_MAINNET_RPC_URL=
CELO_RPC_URL=
EXPLORER_URL=
# Celo mainnet (42220): CHAIN_ID=42220, CHAIN_NAME=celo-mainnet, align PRIVATE_CHAIN_* and PRIVATE_RPC_URL with mainnet; see docs/PRODUCTION-READINESS.md

# Dual-chain operating model
# - PRIVATE_* drives internal settlement + full swarm testing (defaults to Celo Sepolia)
# - PUBLIC_OLAS_* describes the live external request chain that mech-client/mechx uses for Olas attempts
PRIVATE_CHAIN_NAME=celo-sepolia
PRIVATE_CHAIN_ID=11142220
PRIVATE_RPC_URL=
PRIVATE_EXPLORER_URL=
PRIVATE_MARKETPLACE_ADDRESS=
PRIVATE_REVENUE_SERVICE_ADDRESS=

PUBLIC_OLAS_CHAIN_NAME=gnosis
PUBLIC_OLAS_CHAIN_ID=100
PUBLIC_OLAS_RPC_URL=
PUBLIC_OLAS_EXPLORER_URL=

# Marketplace mode (dual-mode execution)
# - private_celo: run our onchain marketplace + escrow settlement on Celo/Anvil
# - public_olas: (future) Olas/Mech adapter intake; may be partially simulated depending on setup
# - hybrid: public adapter intake + private onchain settlement
MARKET_MODE=private_celo

# Report output root (defaults to repo root if unset)
REPORT_OUTPUT_DIR=

# Payment rail mode: mock_payment | xrpl_x402_payment | direct_onchain_celo_payment | hybrid_public_request_xrpl_payment_private_celo_settlement
PAYMENT_RAIL_MODE=direct_onchain_celo_payment

# XRPL machine payments (machine-native service payments)
XRPL_ENABLED=0
XRPL_NETWORK=testnet
XRPL_RPC_URL=https://s.altnet.rippletest.net:51234
XRPL_WALLET_SEED=
# XRPL_SETTLEMENT_WALLET_SEED=  # optional alias: same role as XRPL_WALLET_SEED (autonomous payer)
# XRPL_RECEIVER_SEED=           # legacy name for payer seed only — do not use as T54 payTo; payTo should be Xaman or a distinct receive r-address
XRPL_RECEIVER_ADDRESS=
XRPL_SETTLEMENT_ASSET=XRP
XRPL_X402_ENABLED=0
XRPL_X402_FACILITATOR_URL=
XRPL_PAYMENT_MODE=mock

# x402 broker + swarm_composer (autonomous agent M2M on XRPL Testnet)
# X402_BROKER_PAY_MODE=mock
# X402_BROKER_PAY_MODE=xrpl_testnet
# X402_BROKER_PAY_MODE=xrpl_mainnet  # Path A: real XRP mainnet (requires caps + ack below)
# X402_BROKER_PAY_MODE=xumm_mainnet # Xaman (Xumm) human-in-the-loop mainnet — no agent seed; needs API keys below
# MAX_XRP_SPEND_PER_TX=2            # XRP per 402 tx cap (or MAX_XRP_SPEND_PER_TX_DROPS=integer)
# X402_BROKER_MAINNET_ACK=1         # required for xrpl_mainnet — confirms intentional mainnet spend
# XRPL_PAYER_WALLET_SEED=           # optional alias for XRPL_WALLET_SEED (autonomous x402 payer)
# Typical mainnet: T54 payTo / XRPL_RECEIVER_ADDRESS = Xaman (receive); XRPL_WALLET_SEED = seeded hot wallet that pays (must differ from payTo).
# XUMM_API_KEY=                     # https://apps.xumm.dev/ — put real values in .env or .env.mainnet (never commit)
# XUMM_API_SECRET=
# XUMM_POLL_INTERVAL_SEC=3
# XUMM_POLL_TIMEOUT_SEC=600
# XUMM_SUBMIT=1                     # submit signed Payment via Xaman to XRPL (default on)
# XUMM_SIGNER_ADDRESS=r...         # optional; if payTo equals this (or T54_XRPL_WALLET_ADDRESS), temREDUNDANT — use a different receive address than your Xaman account
# T54_XRPL_RPC_URL=https://xrplcluster.com  # optional; default public mainnet JSON-RPC
# AGENT_XRPL_WALLET_SEED=  # sEd... Testnet seed for the agent; fund via https://faucet.altnet.rippletest.net/
# SWARM_AGENT_XRPL_SEED=  # optional alias for AGENT_XRPL_WALLET_SEED
# SWARM_COMPOSER_VERBOSE=0
# SWARM_COMPOSER_MAX_ITERATIONS=12
# RUN_XRPL_SUBMIT_E2E=0  # set 1 to run packages/agents/tests/test_e2e_xrpl.py live submit test

# T54 XRPL x402 (t54.ai facilitator — mainnet/testnet/local)
# For testnet: use self-hosted xrpl-x402-facilitator; see docs/T54_XRPL_TESTNET_WORKAROUND.md
# T54_XRPL_ENABLED=0
# T54_XRPL_MODE=mainnet|testnet|local
# T54_XRPL_FACILITATOR_URL=http://127.0.0.1:8010  # self-hosted testnet; or t54 mainnet default
# T54_XRPL_NETWORK=testnet|mainnet
# T54_XRPL_NETWORK_PASSPHRASE=
# T54_XRPL_REQUIRE_VALIDATED=0
# T54_XRPL_WALLET_SEED=
# T54_XRPL_WALLET_ADDRESS=
# T54_XRPL_RECEIVER_ADDRESS=
# T54_XRPL_ALLOW_SIMULATED_TESTNET=0
# T54_XRPL_DEFAULT_CURRENCY=XRP
# T54_XRPL_TIMEOUT_MS=30000
# T54_XRPL_DRY_RUN=0

# x402 External Commerce (buy from external payable APIs)
# Bridge: Fund Celo only; LI.FI bridges Celo→Base on demand (X402_BRIDGE_ENABLED=1). No manual Base funding.
# X402_ENABLED=0
# X402_PROTOCOL_VERSION=2
# X402_DISCOVERY_ENABLED=1
# X402_TEST_FACILITATOR_URL=https://x402.org/facilitator
# Base mainnet x402 (USDC): use eip155:8453 only unless you intentionally test Sepolia.
# X402_ALLOWED_NETWORKS=eip155:8453
# AGENT_EVM_PRIVATE_KEY=0x...   # or X402_BUYER_BASE_MAINNET_PRIVATE_KEY= (same wallet; funded with Base USDC)
# X402_BUYER_BASE_SEPOLIA_PRIVATE_KEY= is ignored for EVM x402 (Base mainnet only; remove or leave unset).
# X402_BUYER_PRIVATE_KEY=  # fallback; ROOT_STRATEGIST also used if set
# X402_MAX_SPEND_USD=5
# X402_DRY_RUN=1
# X402_PROVIDERS_JSON=
# x402scout catalog merge (buy-side registry expansion; default off — safe next to dual seller/soak)
# X402_SCOUT_CATALOG_ENABLED=0
# X402_SCOUT_SLIM_JSON=external_commerce_data/x402scout-providers-slim.json
# Rebuild slim: npm run catalog:scout-slim  (requires x402scout-catalog-full.json from npm run catalog:x402scout)
# List yourself on x402scout (HTTPS endpoint URL, not a brand name). Register is free POST; trust score is computed later by Scout.
#   npm run x402scout:register   — needs X402SCOUT_SERVICE_URL or T54_SELLER_PUBLIC_BASE_URL + path (see scripts/x402scout_ops.py)
# Paid ($0.01 USDC Base x402): npm run x402scout:discover | npm run x402scout:scan — set X402_ALLOWED_NETWORKS=eip155:8453 + funded buyer key
# X402SCOUT_SERVICE_URL=https://YOUR_HOST/t54/x402/v1/query
# X402SCOUT_REGISTER_PATH=/x402/v1/query
# X402SCOUT_CATEGORY=utility
# Docs: documentation/x402-t54-base/X402_SCOUT_CATALOG_INTEGRATION.md
#
# Autonomous marketplace buyer (24/7 discovery + budgeted paid probes + optional resale mint)
# documentation/x402-t54-base/MARKETPLACE_AUTONOMOUS.md — npm run marketplace:autonomous:once
# Sane 24/7 preset: env.marketplace.sane.example + npm run marketplace:prep
# MARKETPLACE_CYCLE_INTERVAL_SEC=600
# MARKETPLACE_DISCOVERY_REFRESH_SEC=21600
# MARKETPLACE_MAX_PROVIDERS_PER_CYCLE=3
# MARKETPLACE_MAX_INVOCATIONS_PER_DAY=80
# MARKETPLACE_PROVIDER_COOLDOWN_SEC=10800
# MARKETPLACE_MIN_TRUST_SCORE=0
# MARKETPLACE_NETWORK_ALLOWLIST=eip155:8453
# MARKETPLACE_INCLUDE_XRPL=1
# MARKETPLACE_XRPL_NETWORK_ALLOWLIST=xrpl:1
# (include xrpl:0 for T54 mainnet rows, e.g. MARKETPLACE_XRPL_NETWORK_ALLOWLIST=xrpl:0,xrpl:1)
# MARKETPLACE_HTTP_PORT=8056
# MARKETPLACE_HTTP_HOST=127.0.0.1
# MARKETPLACE_ALLOW_TESTNET=0
# MARKETPLACE_SOURCES_ALLOWLIST=   # e.g. x402scout_catalog,bazaar,remote — empty = all
# MARKETPLACE_PROBE_QUERY=ping
# MARKETPLACE_PROBE_METHOD=auto
# MARKETPLACE_MINT_RESELL=0
# MARKETPLACE_SKIP_OWN_SELLER=1
# MARKETPLACE_SKIP_OLAS_INTAKE_URLS=1   # skip URLs listed in OLAS_INTAKE_JSONL (avoid double pay vs olas:intake:loop)
# MARKETPLACE_EXTRA_SKIP_JSONL=        # optional second JSONL of resource_url rows to skip
# MARKETPLACE_SCOUT_REGISTER=0
# MARKETPLACE_SCOUT_REGISTER_INTERVAL_SEC=604800
# MARKETPLACE_DRY_RUN=0
# MARKETPLACE_INCLUDE_CELO=0
# AIRDROP_FARM_SCORE_THRESHOLD=75  # optional; documented gate for airdrop intelligence reports (scripts/run-airdrop-scout.py)
# XRPL-focused x402 discovery (CDP + PayAI filter): npm run discovery:xrpl
# XRPL_DISCOVERY_CONFIG=packages/agents/config/xrpl_discovery_scan.json
# Discovery keyword scan (CDP + PayAI x402 listings): npm run discovery:keywords
# DISCOVERY_KEYWORD_CONFIG=packages/agents/config/discovery_keyword_scan.json
# DISCOVERY_SCAN_MAX_ITEMS_PER_SOURCE=600
# DISCOVERY_SCAN_PAGE_SIZE=100
# DISCOVERY_SCAN_SLEEP_SECONDS=0.2
# DISCOVERY_SCAN_TIMEOUT_SECONDS=35
# Airdrop — run order: (1) npm run airdrop:pipeline  OR  npm run airdrop:pipeline:skip-discovery  OR  discovery:keywords then airdrop:scout
# AIRDROP_PIPELINE_SKIP_DISCOVERY=1  # optional; scripts/run-airdrop-pipeline.ps1 loads repo-root .env into the process (so this works under npm without exporting in the shell)
#   (2) Review external_commerce_data/airdrop-scans.jsonl — no keys needed for scout
#   (3) Claims only when you have calldata: add contract to airdrop_claim_routing allowed_contracts, queue, approve, dry-run, execute
# Reuse AGENT_EVM wallet for claims: either set AIRDROP_* to match AGENT_EVM_*, or omit AIRDROP_CLAIMANT_PRIVATE_KEY / AIRDROP_CLAIM_WALLET_ADDRESS and use AGENT_EVM_PRIVATE_KEY + AGENT_EVM_PUBLIC_ADDRESS (executor falls back)
# Airdrop claim execution (approval-gated; see documentation/discovery/AIRDROP_CLAIM_EXECUTION.md)
# AIRDROP_CLAIMANT_PRIVATE_KEY=0x...   # dedicated hot wallet for claim txs only
# AIRDROP_CLAIM_WALLET_ADDRESS=0x...   # must match claimant key if routing sets expected_signer_env
# AIRDROP_CLAIM_EXECUTION_ENABLED=0      # set to 1 only when ready to broadcast
# AIRDROP_CLAIM_ALLOW_UNLISTED=0       # 1 = allow contracts not in routing allowlist (dangerous)
# AIRDROP_CLAIM_ROUTING_JSON=packages/agents/config/airdrop_claim_routing.json
# AIRDROP_CLAIM_QUEUE_DB=external_commerce_data/airdrop_claim_queue.sqlite
# Tenderly (optional — python scripts/airdrop-claim-verify.py --tenderly)
# TENDERLY_ACCOUNT_SLUG=
# TENDERLY_PROJECT_SLUG=
# TENDERLY_ACCESS_KEY=
# AIRDROP_INTAKE_WRITE_EXECUTION_PLAN=1   # after npm run airdrop:intake, write airdrop_intake_execution_plan.json
# AIRDROP_INTAKE_SNAPSHOT_JSON=external_commerce_data/airdrop_intake_snapshot.json
# AIRDROP_INTAKE_EXECUTION_PLAN_JSON=external_commerce_data/airdrop_intake_execution_plan.json
# AIRDROP_ALLOW_BATCH_EXECUTE_APPROVED=0  # set 1 only for npm run airdrop:claim:batch-execute
# npm swallows --dry-run when using npm run … -- ; use npm run airdrop:claim:batch-dry-run instead
# npm run airdrop:claim:recon — read-only: wallet, RPC/allowlist per chain, claim queue, 0x scraped from local scout/keyword files
# npm run airdrop:intake — full snapshot: optional discovery + catalog + LLM scout + recon → external_commerce_data/airdrop_intake_snapshot.json (use --skip-discovery for scout-only)
# AIRDROP_INTAKE_CHAIN_IDS=11142220,42220,84532,8453,1,137,56,100
# AIRDROP_INTAKE_PRESET=mainnet   # or: npm run airdrop:intake:mainnet — DefiLlama pass over EVM mainnets only (no Sepolia in list)
# (omit CHAIN_IDS and PRESET to merge routing ∪ airdrop_intake_chains.json)
# AIRDROP_INTAKE_DISCOVERY_TIMEOUT_SEC=7200
# AIRDROP_INTAKE_SCOUT_TIMEOUT_SEC=7200
# npm run airdrop:pull-catalog — fetch DefiLlama airdrop-config → external_commerce_data/airdrop_protocol_catalog.json (verify distributor vs token before allowlisting)
# npm run airdrop:catalog:base — filter catalog for Base 8453 (see scripts/airdrop-catalog-for-chain.py --help)
# npm run airdrop:claim:verify — RPC-check distributor + calldata (see documentation/discovery/CLAIM_EXTRACT_AND_VERIFY.md)
# npm run airdrop:claim:spec-from-merkle — build ClaimSpec JSON from merkle JSON + known `to`
# Local demo (no mainnet): npm run airdrop:claim:demo  — requires Foundry forge + anvil on PATH
# Real Celo Sepolia testnet (mock deploy + claim): npm run airdrop:claim:testnet — needs CELO_SEPOLIA_RPC_URL + funded AIRDROP_CLAIMANT_PRIVATE_KEY
# npm run airdrop:claim:testnet:env — uses swarm role keys; set CLAIM_WALLET_ROLE=FINANCE_DISTRIBUTOR|TREASURY|... (address must match private key)
# Mainnet claim prep: documentation/discovery/AIRDROP_CLAIM_EXECUTION.md (Funding section) + documentation/discovery/airdrop_funding_checklist.example.md — fund AIRDROP_CLAIMANT on each chain_id you execute; Coinbase withdraw to same 0x as claim wallet
# RPCs for airdrop_claim_routing.json (set any chain you use): BASE_MAINNET_RPC_URL, ETHEREUM_MAINNET_RPC_URL / ETH_MAINNET_RPC_URL, BSC_RPC_URL, GNOSIS_RPC_URL, MODE_RPC_URL (chain 34443) — see docs/DISCOVERY_CHAIN_INVENTORY.md
# MODE_RPC_URL=https://mainnet.mode.network
# PUBLIC_PORTAL_URL=https://hobie1kenobi.github.io/agentic-crypto-swarm-prototype/  # optional; overrides metadata.portal_url for swarm-* / t54-xrpl-* (alias: SWARM_PORTAL_URL)
# EXTERNAL_MARKETPLACE_MODE=internal_only
# AGORAGENTIC_API_KEY=amk_...  # optional; enables Bearer-auth execute test
# X402_BRIDGE_ENABLED=1  # on-demand Celo->Base USDC bridge via LI.FI (default 1)
# X402_USE_FACILITATOR=1  # try Celo-native facilitator first (celo_native providers)

# Dhali (optional — off-chain x402 channels; Portal + reverse proxy or facilitator URL)
# Docs: documentation/dhali/DHALI_INTEGRATION.md | https://dhali.io/docs/
# DHALI_REVERSE_PROXY_UPSTREAM_URL=https://YOUR_HOST/t54   # same HTTPS origin as T54_SELLER_PUBLIC_BASE_URL (Portal upstream)
# DHALI_FACILITATOR_URL=https://x402.api.dhali.io/v2/...   # from https://app.dhali.io/ asset dashboard
# DHALI_ASSET_ID=                                         # optional UUID for your notes
# DHALI_TARGET_URL=                                       # optional; scripts/dhali_m2m_example.py probe target
# DHALI_M2M_MODE=xrpl                                     # or evm for dhali-py channel (see requirements-dhali.txt)
# npm run dhali:check
# npm run dhali:upstream   # print URL to paste into Dhali Portal reverse-proxy upstream
# npm run dhali:m2m
# npm run dhali:m2m:pay    # dhali-py channel + retry (needs funded Dhali channel)
# npm run dhali:bithomp    # print PAYMENT_CLAIM + curl for bithomp.dhali.io (see documentation/dhali/DHALI_INTEGRATION.md)
# DHALI_BITHOMP_BASE_URL=https://bithomp.dhali.io
# DHALI_BITHOMP_PATH=/api/v2/address/rvYAfWj5gh67oV6fW32ZzP3Aw4Eubs59B?username=true
# Dhali Payment-Claim (pay.dhali.io) — copy env.dhali.local.example to .env.dhali.local (gitignored)
# DHALI_PAYMENT_CLAIM=
# DHALI_PROXY_URL=
# pip install -r requirements-dhali.txt

# x402 seller (Base USDC via facilitator — Coinbase Bazaar; see api_seller_x402.py)
# X402_SELLER_HOST=0.0.0.0
# X402_SELLER_PORT=8043
# X402_SELLER_PAY_TO=0x...   # optional; default: address from ROOT_STRATEGIST_PRIVATE_KEY
# X402_SELLER_PRICE=$0.01
# X402_SELLER_NETWORK=eip155:8453   # Base mainnet Bazaar; use eip155:84532 for Base Sepolia dev
# X402_TEST_FACILITATOR_URL=https://x402.org/facilitator
# X402_SELLER_PUBLIC_URL=https://your-ngrok-url.ngrok.io/x402/v1/query  # HTTPS required for external buyers
# X402_SELLER_DATA_PRICE=$0.05  # GET /x402/v1/celo-agent-data (Celo + proof bundle); default $0.05
# X402_INTAKE_RESALE_PRICE=$0.05  # GET /x402/v1/intake-resale (same artifacts/intake_resale/ as T54); default $0.05
# X402_INTAKE_RESALE_PUBLIC_URL=https://your-host/x402/v1/intake-resale  # optional; else derived from X402_SELLER_PUBLIC_URL (see swarm-seller-intake-resale in x402_providers.json)
# X402_SELLER_DEEP_AUDIT_MAX_TIMEOUT_SECONDS=180   # GET /contract-audit — x402 v2 maxTimeoutSeconds (one session payment covers full Slither+RPC pipeline; not per sub-call)
# X402_SELLER_MONITOR_MAX_TIMEOUT_SECONDS=300      # POST /contract-monitor — longer auth window for subscription body + settlement
# X402_FACILITATOR_HEALTH_DISABLE=0  # set 1 to skip facilitator ping + 503 gate on Base seller
# INTAKE_RESALE_404_PER_MIN=5  # rate limit per IP for unknown/missing pack_id (enumeration protection)
# T54_FACILITATOR_HEALTH_DISABLE=0  # set 1 to skip facilitator ping + 503 gate on T54 seller
# T54_SKU_TARGET_USD_INTAKE_RESALE=0.05  # scripts/update_sku_prices.py — drops price for intake-resale-pack in t54_seller_skus.json
# X402_SELLER_DATA_PUBLIC_URL=https://your-ngrok-url.ngrok.io/x402/v1/celo-agent-data  # optional; discovery uses this or derives from X402_SELLER_PUBLIC_URL (/query -> /celo-agent-data)
# GitHub Pages: npm run docs:sync-endpoints — writes docs/endpoints.json for the public portal
# X402_SELLER_PROBE_URL=http://127.0.0.1:8043/x402/v1/query  # optional; for probe-x402-seller.py
# X402_ENABLED=1
# X402_DISCOVERY_ENABLED=1
# X402_ALLOWED_NETWORKS=eip155:8453
#
# ClawCredit (OpenClaw buyer only) — does NOT affect t54/Base sellers. Optional local file: copy .env.clawcredit.example -> .env.clawcredit (gitignored).
# documentation/x402-t54-base/CLAWCREDIT_INTEGRATION.md | npm run clawcredit:setup

# Optional JSONL: one line per HTTP request to api_402 + api_seller_x402 (hits / probes / paid calls)
# SELLER_ACCESS_LOG=seller_access.log
# X402_FACILITATOR_MAINNET=https://facilitator.ultravioletadao.xyz
# X402_FACILITATOR_TESTNET=https://x402.org/facilitator
# X402_AUTO_PAUSE=1  # pause for manual faucet when testnet balance low
#
# Stripe Machine Payments Protocol (MPP) — optional; does not affect x402/T54 unless enabled
# Docs: docs/STRIPE_MPP_INTEGRATION.md — Python helpers for PaymentIntent crypto deposit (Tempo)
# STRIPE_MPP_ENABLED=0
# STRIPE_SECRET_KEY=
# Optional reference only — deposit-intent does not use pmc_ (see docs/STRIPE_MPP_INTEGRATION.md)
# STRIPE_PAYMENT_METHOD_CONFIGURATION=
# STRIPE_MPP_TESTNET=1
# STRIPE_API_VERSION=2026-03-04.preview
#
# Marketplace — sellable x402 Strategy Dashboard bundle (Stripe MPP crypto deposit on Tempo)
# Docs: docs/MARKETPLACE_DASHBOARD_BUNDLE.md — does not replace x402/T54; optional HTTP API on port 8055
# MARKETPLACE_HTTP_ENABLED=0
# MARKETPLACE_HTTP_HOST=127.0.0.1
# MARKETPLACE_HTTP_PORT=8055
# MARKETPLACE_DASHBOARD_BUNDLE_PRICE_USD=49.00
# MARKETPLACE_ORDERS_DIR=marketplace/orders
# (1) After npm run marketplace:pack — stable file for downloads:
# MARKETPLACE_BUNDLE_ZIP_PATH=dist/x402-strategy-dashboard-bundle-latest.zip
# (2) Webhook signing secret — Dashboard endpoint OR `npm run marketplace:webhook-dev` (Stripe CLI prints whsec_...):
# STRIPE_WEBHOOK_SECRET=whsec_...
# (3) Production public origin for links in API JSON (optional locally — URLs also use request Host):
# MARKETPLACE_PUBLIC_BASE_URL=https://your-domain.example
#
# Unified host (Caddy :9080 + one ngrok): see scripts/reverse-proxy/README.md
# Stable HTTPS without opening router ports — Cloudflare Tunnel: scripts/cloudflare-tunnel/README.md
# X402_SELLER_PUBLIC_URL=https://YOUR_HOST/x402/v1/query
# T54_SELLER_PUBLIC_BASE_URL=https://YOUR_HOST/t54
# T54_SELLER_ALLOW_DUPLICATE=1  # tests only — scripts/t54_seller_server.py uses a single-instance lock by default
# MCP server (scripts/mcp_server.py — Model Context Protocol stdio; exposes T54 OpenAPI tools + x402_broker_client)
# pip install "mcp[cli]" pyyaml
# X402_MCP_OPENAPI_PATH=documentation/x402-t54-base/openapi/agentic-swarm-t54-skus.openapi.yaml
# X402_MCP_DRY_RUN=1          # optional — mock_pay_invoice only (no XRPL settlement)
# X402_MCP_TIMEOUT_SEC=120
# Remote MCP (SSE) — Agent.ai / browser clients; bind local, expose via Caddy :9080/mcp/* + tunnel
# X402_MCP_SSE_HOST=127.0.0.1
# X402_MCP_SSE_PORT=9051
# Remote MCP (Streamable HTTP) — Smithery/Glama URL; Caddy exact /mcp → this port (requires mcp>=1.23)
# X402_MCP_STREAMABLE_PORT=9052
# Optional: MCP_HTTP_ALLOWED_HOSTS=api.example.com  (DNS rebinding allowlist; default protection off)
# npm run mcp:t54:sse   OR   powershell -File scripts/run-mcp-t54-sse.ps1
# npm run mcp:t54:streamable-http
# Public base path (no trailing slash) for docs/endpoints.json — same origin as unified stack:
# MCP_SSE_PUBLIC_URL=https://YOUR_TUNNEL_HOST/mcp
# MARKETPLACE_PUBLIC_BASE_URL=https://YOUR_HOST
# OAuth/OIDC discovery (optional — defaults advertise this API host; set all three URLs to delegate to your IdP):
# OAUTH_ISSUER=https://YOUR_HOST
# OAUTH_AUTHORIZATION_ENDPOINT=https://YOUR_IDP/oauth2/authorize
# OAUTH_TOKEN_ENDPOINT=https://YOUR_IDP/oauth2/token
# OAUTH_JWKS_URI=https://YOUR_IDP/.well-known/jwks.json
# OAUTH_JWKS_JSON={"keys":[]}
# RFC 9728 protected resource metadata (optional overrides):
# OAUTH_RESOURCE_IDENTIFIER=https://YOUR_HOST
# OAUTH_AUTHORIZATION_SERVERS=https://YOUR_IDP,https://YOUR_SECOND_AS
# CELO_PRIVATE_KEY=  # or ROOT_STRATEGIST_PRIVATE_KEY; same key = same address on Celo + Base
# CELO_SEPOLIA_RPC_URL=  # for testnet
# CELO_MAINNET_RPC_URL=  # for mainnet bridge
# BASE_SEPOLIA_RPC_URL=  # for faucet balance check
# BASE_MAINNET_RPC_URL=  # for mainnet balance check

# Olas / Mech adapter (public mode)
# Supported by mech-client: gnosis, base, polygon, optimism (NOT Celo).
OLAS_ENABLED=0
OLAS_CHAIN_CONFIG=gnosis
OLAS_PRIORITY_MECH_ADDRESS=
OLAS_TOOL=openai-gpt-4o-2024-05-13
# EOA key used to pay/send Olas requests (keep funded on the selected OLAS chain)
OLAS_EOA_PRIVATE_KEY=
# Max time to wait for delivery (seconds)
OLAS_DELIVERY_TIMEOUT_SEC=180
OLAS_MECHX_PATH=

# Olas intake router (packages/agents/olas_intake — maps Olas payloads → T54 x402 SKUs)
# See documentation/operations/OLAS_INTAKE_AGENT.md
OLAS_INTAKE_SOURCE=mock
# OLAS_INTAKE_SOURCE=jsonl
# OLAS_INTAKE_JSONL=path/to/demands.jsonl
# --- External x402 via JSONL resource_url (not your ngrok T54 base) ---
# Default payment_rail is **xrpl** (T54 / xrpl:0): same broker as `X402_BROKER_PAY_MODE` + XRPL payer seed.
# For Base/USDC listings only, set "payment_rail":"evm" on the line (uses X402Buyer + EVM key).
# Agent Base burner (optional): python scripts/generate_evm_wallet.py  -> AGENT_EVM_PRIVATE_KEY / AGENT_EVM_PUBLIC_ADDRESS (Olas EVM intake uses this first in X402Buyer)
# Olas + discovery (Base USDC): OLAS_INTAKE_JSONL=external_commerce_data/olas_intake_operational.jsonl, payment_rail evm, AGENT_EVM_PRIVATE_KEY funded on Base
# Full XRPL discovery export: npm run discovery:xrpl && npm run olas:intake:export-xrpl  -> external_commerce_data/olas_intake_xrpl_targets.jsonl
# Curated rails (recommended): npm run discovery:xrpl && npm run olas:intake:annotate  -> external_commerce_data/olas_intake_operational.jsonl
# T54 discovery export: npm run discovery:xrpl:t54 && npm run olas:intake:export-t54
# X402_ALLOWED_NETWORKS=eip155:8453
# First network wins when a 402 lists multiple accepts (list Base mainnet first).
# X402_EVM_PAYMENT_ATTEMPTS=4
# X402_SETTLEMENT_RETRY_DELAY_SEC=8
# Optional: block EIP-3009 signing if price exceeds cap (6-decimal USDC units or decimal USDC string)
# MAX_USDC_SPEND_PER_TX_ATOMIC=10000
# MAX_USDC_SPEND_PER_TX=0.01
# X402_BUYER_PRIVATE_KEY=0x...   # evm rail only; or ROOT_STRATEGIST_PRIVATE_KEY
# X402_TEST_FACILITATOR_URL=https://x402.org/facilitator
# Example lines: packages/agents/config/olas_intake_external_targets.example.jsonl
# 24/7 worker: python -m olas_intake.run --loop  (or npm run olas:intake:daemon)
# OLAS_INTAKE_LOOP=1
# OLAS_INTAKE_LOOP_INTERVAL_SEC=300
# Optional: Gemma/Ollama summary after each T54 result (get_llm_synthesis: smaller num_predict + timeout + retries)
# OLAS_INTAKE_LLM=1
# OLAS_INTAKE_OLLAMA_MODEL=gemma3:4b-cloud
# OLAS_INTAKE_LLM_MAX_CHARS=4000
# OLAS_INTAKE_LLM_RETRIES=3
# OLAS_INTAKE_LLM_NUM_PREDICT=512
# OLAS_INTAKE_LLM_NUM_CTX=8192
# OLLAMA_TIMEOUT=180
# logs/olas-intake.log + logs/olas-intake-failures.log (gitignored); loop stderr banner after N bad batches:
# OLAS_INTAKE_FAIL_ALERT_THRESHOLD=3
# After a successful T54 purchase (HTTP 200), persist the JSON body for paid resale (GET /x402/v1/intake-resale?pack_id=):
# OLAS_INTAKE_MINT_RESELL=1
# T54_INTAKE_RESALE_DIR=artifacts/intake_resale
# Load .env.mainnet again with override so mainnet XRPL broker mode / T54 URL win over .env.local (live intake):
# OLAS_INTAKE_DOTENV_MAINNET_OVERRIDE=1

# Legacy / optional: Base Sepolia (set CHAIN_NAME=base-sepolia, CHAIN_ID=84532)
ALCHEMY_API_KEY=

# Coinbase Developer Platform (CDP) — Python SDK: pip install cdp-sdk — CdpClient() loads from env
# Create API key + wallet secret in portal: https://portal.cdp.coinbase.com/access/api
# Docs: https://coinbase.github.io/cdp-sdk/python
# CDP_WALLET_SECRET is required for import_account + send_transaction (not for list_accounts only)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# Optional: scripts/cdp_smoke.py --write-smoke (default base-sepolia)
# CDP_SMOKE_NETWORK=base-sepolia

# Ollama — sellers (api_402 / api_seller_x402 / T54) use swarm/llm.get_llm()
#
# A) Cloud models via local daemon (low local RAM): install Ollama app, then:
#    ollama signin
#    ollama pull gemma3:4b-cloud
#    Keep the daemon running; point sellers at localhost (default below).
OLLAMA_MODEL=gemma3:4b-cloud
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_DRY_RUN=0
#
# B) Direct Ollama Cloud API (no local daemon): key from https://ollama.com/settings/keys
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_API_KEY=
# OLLAMA_MODEL=kimi-k2.5:cloud
#
# C) Fully local small models (~8–9 GiB RAM): e.g. qwen3.5:9b, llama3.1:8b
# OLLAMA_MODEL=qwen3.5:9b
# OLLAMA_BASE_URL=http://127.0.0.1:11434
#
# D) Swarm composer (packages/agents/swarm_composer.py) + Gemma cloud: e.g. gemma3:4b-cloud (see A).
#    Fully local Gemma: ollama pull gemma3:4b (no -cloud).
# OLLAMA_MODEL=gemma3:4b
# OLLAMA_BASE_URL=http://127.0.0.1:11434
#
# Live sellers (uvicorn / unified stack): do NOT set LLM_DRY_RUN=1 in .env or .env.local — it forces stub LLM.
# Local harness only: scripts/local-harness.ps1 sets LLM_DRY_RUN=1, or set in the shell for that session.

# Human beneficiary (EOA on Celo Sepolia / Celo mainnet)
BENEFICIARY_ADDRESS=0x0000000000000000000000000000000000000000

# ERC-4337 Bundler / Paymaster (optional; Pimlico supports Base Sepolia; Celo may use other bundlers)
PIMLICO_API_KEY=
BUNDLER_RPC_URL=
PAYMASTER_RPC_URL=

# Agent wallet private keys (generated by create-accounts, DO NOT COMMIT)
ROOT_STRATEGIST_PRIVATE_KEY=
IP_GENERATOR_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=
FINANCE_DISTRIBUTOR_PRIVATE_KEY=

# Dual-chain "concept keys" (optional aliases):
# - WORKER_PRIVATE_KEY feeds the internal worker role (IP_GENERATOR)
# - VALIDATOR_PRIVATE_KEY feeds the internal validator role (DEPLOYER)
WORKER_PRIVATE_KEY=
VALIDATOR_PRIVATE_KEY=

# If you separate treasury from the requester/worker in your custom config, you can define:
TREASURY_PRIVATE_KEY=

# Agent smart account addresses (filled by create-accounts)
ROOT_STRATEGIST_ADDRESS=
IP_GENERATOR_ADDRESS=
DEPLOYER_ADDRESS=
FINANCE_DISTRIBUTOR_ADDRESS=

# Deploy (for broadcast): EOA private key with testnet native token (CELO on Celo Sepolia)
PRIVATE_KEY=

# Payment (optional override; default 0.001 native token, must match AgentRevenueService MIN_PAYMENT)
# PAYMENT_WEI=1000000000000000

# Customer balance layer (pre-funded balances from XRPL receipts)
# When enabled, XRPL payments credit customer balance; task creation debits balance
# CUSTOMER_BALANCE_ENABLED=0
# CUSTOMER_BALANCE_DB_PATH=

# Pricing & metering
# TASK_ESCROW_ETH=0.01
# PRICING_TASK_XRP=1
# PRICING_TASK_RLUSD=1
# PRICING_XRP_TO_ETH=0.01
# PRICING_XRP_TO_WEI=
# PRICING_RLUSD_TO_ETH=0.01
# PRICING_RLUSD_TO_WEI=

# Deployed addresses (filled after deployment or fetch-and-save-addresses)
TREASURY_ADDRESS=
REVENUE_SERVICE_ADDRESS=
CONSTITUTION_ADDRESS=
COMPUTE_MARKETPLACE_ADDRESS=

# Compute marketplace miner/validator (optional)
COMPUTE_MINER_METADATA=swarm-agent-1
COMPUTE_MINER_URLS=http://127.0.0.1:8043
COMPUTE_TASK_QUERY=What is one ethical use of AI?

# Optional: payment token for future ERC-20 payment layer
PAYMENT_TOKEN_ADDRESS=

# Market realism soak (quote-driven XRPL, reconciliation, multi-actor)
# XRPL_QUOTE_DRIVEN=1
# XRPL_ALLOW_MOCK_FALLBACK=0
# RECONCILIATION_ENABLED=1
# XRPL_QUOTE_VALIDITY_SECONDS=300
# XRPL_AMOUNT_TOLERANCE_PCT=0.1
# XRPL_DESTINATION_TAG_BASE=100000
# RECONCILIATION_DB_PATH=
# REALISM_REQUESTER_ROLES=ROOT_STRATEGIST,IP_GENERATOR,DEPLOYER
# REALISM_WORKER_ROLES=IP_GENERATOR,DEPLOYER,FINANCE_DISTRIBUTOR,TREASURY
# REALISM_VALIDATOR_ROLES=DEPLOYER,FINANCE_DISTRIBUTOR
# FAILURE_INJECTION_ENABLED=0
# FAILURE_INJECTION_WEIGHTS=
# FAILURE_INJECTION_FLAGS=
# REALISM_DURATION_HOURS=6
# REALISM_MAX_CYCLES=

# LLM (optional overrides — prefer top Ollama block for OLLAMA_MODEL / OLLAMA_API_KEY)
OPENAI_API_KEY=
GROQ_API_KEY=

# Smithery Platform API (runtime logs / invocations). Put the real value in .env.local — never commit keys.
# Docs: https://smithery.ai/docs/api-reference/servers/list-runtime-logs.md
SMITHERY_API_KEY=
# Must match the server page path exactly (this repo’s Smithery space).
SMITHERY_QUALIFIED_NAME=hobiecunningham/agentic-swarm-marketplace
