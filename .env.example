# Chain (Celo-first: celo-sepolia testnet, celo-mainnet production; local: anvil)
# Celo Sepolia public test: CHAIN_NAME=celo-sepolia, CHAIN_ID=11142220, set RPC and fund deployer + ROOT_STRATEGIST
CHAIN_NAME=celo-sepolia
CHAIN_ID=11142220
RPC_URL=
CELO_SEPOLIA_RPC_URL=
CELO_MAINNET_RPC_URL=
CELO_RPC_URL=
EXPLORER_URL=
# Celo mainnet (42220): CHAIN_ID=42220, CHAIN_NAME=celo-mainnet, align PRIVATE_CHAIN_* and PRIVATE_RPC_URL with mainnet; see docs/PRODUCTION-READINESS.md

# Dual-chain operating model
# - PRIVATE_* drives internal settlement + full swarm testing (defaults to Celo Sepolia)
# - PUBLIC_OLAS_* describes the live external request chain that mech-client/mechx uses for Olas attempts
PRIVATE_CHAIN_NAME=celo-sepolia
PRIVATE_CHAIN_ID=11142220
PRIVATE_RPC_URL=
PRIVATE_EXPLORER_URL=
PRIVATE_MARKETPLACE_ADDRESS=
PRIVATE_REVENUE_SERVICE_ADDRESS=

PUBLIC_OLAS_CHAIN_NAME=gnosis
PUBLIC_OLAS_CHAIN_ID=100
PUBLIC_OLAS_RPC_URL=
PUBLIC_OLAS_EXPLORER_URL=

# Marketplace mode (dual-mode execution)
# - private_celo: run our onchain marketplace + escrow settlement on Celo/Anvil
# - public_olas: (future) Olas/Mech adapter intake; may be partially simulated depending on setup
# - hybrid: public adapter intake + private onchain settlement
MARKET_MODE=private_celo

# Report output root (defaults to repo root if unset)
REPORT_OUTPUT_DIR=

# Payment rail mode: mock_payment | xrpl_x402_payment | direct_onchain_celo_payment | hybrid_public_request_xrpl_payment_private_celo_settlement
PAYMENT_RAIL_MODE=direct_onchain_celo_payment

# XRPL machine payments (machine-native service payments)
XRPL_ENABLED=0
XRPL_NETWORK=testnet
XRPL_RPC_URL=https://s.altnet.rippletest.net:51234
XRPL_WALLET_SEED=
XRPL_RECEIVER_ADDRESS=
XRPL_SETTLEMENT_ASSET=XRP
XRPL_X402_ENABLED=0
XRPL_X402_FACILITATOR_URL=
XRPL_PAYMENT_MODE=mock

# T54 XRPL x402 (t54.ai facilitator — mainnet/testnet/local)
# For testnet: use self-hosted xrpl-x402-facilitator; see docs/T54_XRPL_TESTNET_WORKAROUND.md
# T54_XRPL_ENABLED=0
# T54_XRPL_MODE=mainnet|testnet|local
# T54_XRPL_FACILITATOR_URL=http://127.0.0.1:8010  # self-hosted testnet; or t54 mainnet default
# T54_XRPL_NETWORK=testnet|mainnet
# T54_XRPL_NETWORK_PASSPHRASE=
# T54_XRPL_REQUIRE_VALIDATED=0
# T54_XRPL_WALLET_SEED=
# T54_XRPL_WALLET_ADDRESS=
# T54_XRPL_RECEIVER_ADDRESS=
# T54_XRPL_ALLOW_SIMULATED_TESTNET=0
# T54_XRPL_DEFAULT_CURRENCY=XRP
# T54_XRPL_TIMEOUT_MS=30000
# T54_XRPL_DRY_RUN=0

# x402 External Commerce (buy from external payable APIs)
# Bridge: Fund Celo only; LI.FI bridges Celo→Base on demand (X402_BRIDGE_ENABLED=1). No manual Base funding.
# X402_ENABLED=0
# X402_PROTOCOL_VERSION=2
# X402_DISCOVERY_ENABLED=1
# X402_TEST_FACILITATOR_URL=https://x402.org/facilitator
# X402_ALLOWED_NETWORKS=eip155:84532
# X402_BUYER_BASE_SEPOLIA_PRIVATE_KEY=
# X402_BUYER_PRIVATE_KEY=  # fallback; ROOT_STRATEGIST also used if set
# X402_MAX_SPEND_USD=5
# X402_DRY_RUN=1
# X402_PROVIDERS_JSON=
# EXTERNAL_MARKETPLACE_MODE=internal_only
# AGORAGENTIC_API_KEY=amk_...  # optional; enables Bearer-auth execute test
# X402_BRIDGE_ENABLED=1  # on-demand Celo->Base USDC bridge via LI.FI (default 1)
# X402_USE_FACILITATOR=1  # try Celo-native facilitator first (celo_native providers)

# x402 seller (Base USDC via facilitator — Coinbase Bazaar; see api_seller_x402.py)
# X402_SELLER_HOST=0.0.0.0
# X402_SELLER_PORT=8043
# X402_SELLER_PAY_TO=0x...   # optional; default: address from ROOT_STRATEGIST_PRIVATE_KEY
# X402_SELLER_PRICE=$0.01
# X402_SELLER_NETWORK=eip155:8453   # Base mainnet Bazaar; use eip155:84532 for Base Sepolia dev
# X402_TEST_FACILITATOR_URL=https://x402.org/facilitator
# X402_SELLER_PUBLIC_URL=https://your-ngrok-url.ngrok.io/x402/v1/query  # HTTPS required for external buyers
# GitHub Pages: npm run docs:sync-endpoints — writes docs/endpoints.json for the public portal
# X402_SELLER_PROBE_URL=http://127.0.0.1:8043/x402/v1/query  # optional; for probe-x402-seller.py
# X402_ENABLED=1
# X402_DISCOVERY_ENABLED=1
# X402_ALLOWED_NETWORKS=eip155:8453,eip155:84532

# Optional JSONL: one line per HTTP request to api_402 + api_seller_x402 (hits / probes / paid calls)
# SELLER_ACCESS_LOG=seller_access.log
# X402_FACILITATOR_MAINNET=https://facilitator.ultravioletadao.xyz
# X402_FACILITATOR_TESTNET=https://x402.org/facilitator
# X402_AUTO_PAUSE=1  # pause for manual faucet when testnet balance low
# CELO_PRIVATE_KEY=  # or ROOT_STRATEGIST_PRIVATE_KEY; same key = same address on Celo + Base
# CELO_SEPOLIA_RPC_URL=  # for testnet
# CELO_MAINNET_RPC_URL=  # for mainnet bridge
# BASE_SEPOLIA_RPC_URL=  # for faucet balance check
# BASE_MAINNET_RPC_URL=  # for mainnet balance check

# Olas / Mech adapter (public mode)
# Supported by mech-client: gnosis, base, polygon, optimism (NOT Celo).
OLAS_ENABLED=0
OLAS_CHAIN_CONFIG=gnosis
OLAS_PRIORITY_MECH_ADDRESS=
OLAS_TOOL=openai-gpt-4o-2024-05-13
# EOA key used to pay/send Olas requests (keep funded on the selected OLAS chain)
OLAS_EOA_PRIVATE_KEY=
# Max time to wait for delivery (seconds)
OLAS_DELIVERY_TIMEOUT_SEC=180
OLAS_MECHX_PATH=

# Legacy / optional: Base Sepolia (set CHAIN_NAME=base-sepolia, CHAIN_ID=84532)
ALCHEMY_API_KEY=

# Ollama (local, no API key). qwen3:8b recommended; use tinyllama if low RAM.
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Human beneficiary (EOA on Celo Sepolia / Celo mainnet)
BENEFICIARY_ADDRESS=0x0000000000000000000000000000000000000000

# ERC-4337 Bundler / Paymaster (optional; Pimlico supports Base Sepolia; Celo may use other bundlers)
PIMLICO_API_KEY=
BUNDLER_RPC_URL=
PAYMASTER_RPC_URL=

# Agent wallet private keys (generated by create-accounts, DO NOT COMMIT)
ROOT_STRATEGIST_PRIVATE_KEY=
IP_GENERATOR_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=
FINANCE_DISTRIBUTOR_PRIVATE_KEY=

# Dual-chain "concept keys" (optional aliases):
# - WORKER_PRIVATE_KEY feeds the internal worker role (IP_GENERATOR)
# - VALIDATOR_PRIVATE_KEY feeds the internal validator role (DEPLOYER)
WORKER_PRIVATE_KEY=
VALIDATOR_PRIVATE_KEY=

# If you separate treasury from the requester/worker in your custom config, you can define:
TREASURY_PRIVATE_KEY=

# Agent smart account addresses (filled by create-accounts)
ROOT_STRATEGIST_ADDRESS=
IP_GENERATOR_ADDRESS=
DEPLOYER_ADDRESS=
FINANCE_DISTRIBUTOR_ADDRESS=

# Deploy (for broadcast): EOA private key with testnet native token (CELO on Celo Sepolia)
PRIVATE_KEY=

# Payment (optional override; default 0.001 native token, must match AgentRevenueService MIN_PAYMENT)
# PAYMENT_WEI=1000000000000000

# Customer balance layer (pre-funded balances from XRPL receipts)
# When enabled, XRPL payments credit customer balance; task creation debits balance
# CUSTOMER_BALANCE_ENABLED=0
# CUSTOMER_BALANCE_DB_PATH=

# Pricing & metering
# TASK_ESCROW_ETH=0.01
# PRICING_TASK_XRP=1
# PRICING_TASK_RLUSD=1
# PRICING_XRP_TO_ETH=0.01
# PRICING_XRP_TO_WEI=
# PRICING_RLUSD_TO_ETH=0.01
# PRICING_RLUSD_TO_WEI=

# Deployed addresses (filled after deployment or fetch-and-save-addresses)
TREASURY_ADDRESS=
REVENUE_SERVICE_ADDRESS=
CONSTITUTION_ADDRESS=
COMPUTE_MARKETPLACE_ADDRESS=

# Compute marketplace miner/validator (optional)
COMPUTE_MINER_METADATA=swarm-agent-1
COMPUTE_MINER_URLS=http://127.0.0.1:8043
COMPUTE_TASK_QUERY=What is one ethical use of AI?

# Optional: payment token for future ERC-20 payment layer
PAYMENT_TOKEN_ADDRESS=

# Market realism soak (quote-driven XRPL, reconciliation, multi-actor)
# XRPL_QUOTE_DRIVEN=1
# XRPL_ALLOW_MOCK_FALLBACK=0
# RECONCILIATION_ENABLED=1
# XRPL_QUOTE_VALIDITY_SECONDS=300
# XRPL_AMOUNT_TOLERANCE_PCT=0.1
# XRPL_DESTINATION_TAG_BASE=100000
# RECONCILIATION_DB_PATH=
# REALISM_REQUESTER_ROLES=ROOT_STRATEGIST,IP_GENERATOR,DEPLOYER
# REALISM_WORKER_ROLES=IP_GENERATOR,DEPLOYER,FINANCE_DISTRIBUTOR,TREASURY
# REALISM_VALIDATOR_ROLES=DEPLOYER,FINANCE_DISTRIBUTOR
# FAILURE_INJECTION_ENABLED=0
# FAILURE_INJECTION_WEIGHTS=
# FAILURE_INJECTION_FLAGS=
# REALISM_DURATION_HOURS=6
# REALISM_MAX_CYCLES=

# LLM (optional overrides)
OLLAMA_MODEL=
OPENAI_API_KEY=
GROQ_API_KEY=
