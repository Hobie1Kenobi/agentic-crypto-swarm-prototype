# Base Sepolia RPC (Alchemy)
ALCHEMY_API_KEY=your_alchemy_api_key
RPC_URL=https://base-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# LLM (Groq preferred)
LLM_API_KEY=your_groq_or_openai_key
LLM_PROVIDER=groq

# Human beneficiary (EOA on Base Sepolia)
BENEFICIARY_ADDRESS=0x0000000000000000000000000000000000000000

# ERC-4337 Bundler / Paymaster (Pimlico)
PIMLICO_API_KEY=your_pimlico_api_key

# Agent wallet private keys (generated by create-accounts, DO NOT COMMIT)
ROOT_STRATEGIST_PRIVATE_KEY=
IP_GENERATOR_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=
FINANCE_DISTRIBUTOR_PRIVATE_KEY=

# Agent smart account addresses (filled by create-accounts)
ROOT_STRATEGIST_ADDRESS=
IP_GENERATOR_ADDRESS=
DEPLOYER_ADDRESS=
FINANCE_DISTRIBUTOR_ADDRESS=

# Deployed addresses (filled after deployment)
TREASURY_ADDRESS=
REVENUE_SERVICE_ADDRESS=

# Chain
CHAIN_ID=84532
